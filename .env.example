# Server
# Runtime environment: development | production | test
NODE_ENV=development
# Port the Express server listens on
PORT=5051
# Origin the Vite dev server runs on (used for CORS)
CLIENT_URL=http://localhost:5050

# Client (Vite — prefix VITE_ required)
# Base URL for API requests. Leave empty to use the Vite dev proxy.
VITE_API_URL=
# Application display name shown in the UI
VITE_APP_NAME=AppyStack
# Socket.io server URL. Leave empty to use window.location.origin (default).
# Set explicitly to bypass Vite WebSocket proxy upgrade issues in dev.
VITE_SOCKET_URL=http://localhost:5051

# Git sync polling interval in milliseconds (default: 120000 = 2 minutes)
# GIT_SYNC_POLL_MS=120000
